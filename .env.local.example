# ─────────────────────────────────────────────────────────────
# Root View – Environment Variables
# Copy this file to .env.local and fill in each value.
# See SETUP_GUIDE_FOR_BRIAN.md for step-by-step instructions.
# ─────────────────────────────────────────────────────────────

# Chat button in the top bar links here (NotebookLM notebook URL)
NEXT_PUBLIC_NOTEBOOKLM_URL=

# Google Sheets — File > Share > Publish to web > Embed tab
# Get one URL per tab (BOM, Costs, Ledger, Dashboard)
NEXT_PUBLIC_SHEETS_BOM_URL=
NEXT_PUBLIC_SHEETS_COSTS_URL=
NEXT_PUBLIC_SHEETS_LEDGER_URL=
NEXT_PUBLIC_SHEETS_DASHBOARD_URL=

# Trello board — Board menu > Print, export, and share > Link/Embed
NEXT_PUBLIC_TRELLO_URL=

# Google Drive folder — right-click folder > Share > Anyone with link > copy link
NEXT_PUBLIC_DRIVE_FOLDER_URL=

# ── Optional ──────────────────────────────────────────────────
# GitHub repo for the device firmware/app code
NEXT_PUBLIC_GITHUB_REPO_URL=

# Expo Snack or StackBlitz embed URL for the Code page
NEXT_PUBLIC_CODE_EMBED_URL=

# YouTube unlisted video URL(s) — comma-separated if multiple
NEXT_PUBLIC_VIDEO_URL=
